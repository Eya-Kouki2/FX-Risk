# Copy this file to `.env` and fill in your Supabase project values.
# Find them in Supabase: Project Settings → API

# --- Client (Vite / browser) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# --- Server (SSR / TanStack Start) ---
# Same values as above, without the VITE_ prefix
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# --- Server admin only (seed, trusted server functions) ---
# Never expose this key in client code or commit a real value to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
